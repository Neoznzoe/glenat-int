# Template pour .env.developpement / .env.recette / .env.production
# Copier ce fichier sous le nom de l'environnement cible et remplir les valeurs.

# Clé AES-256-GCM encodée en Base64 URL-safe pour les URLs sécurisées
VITE_AES_GCM_KEY=

# OAuth — base URL et identifiants (les endpoints sont construits dans src/lib/oauth.ts)
VITE_OAUTH_BASE_URL=https://api.example.com/Api/v2.0/OAuth
VITE_OAUTH_CLIENT_ID=sys-api-core-<instance>
VITE_OAUTH_CLIENT_SECRET=""
VITE_OAUTH_SCOPE=""
VITE_OAUTH_STORAGE_KEY=

# Clé publique RSA pour le chiffrement des paramètres d'URL
VITE_SECURE_API_PUBLIC_KEY=""

# Nom du projet Docker Compose (préfixe les conteneurs/réseaux/volumes)
COMPOSE_PROJECT_NAME=glenat-intranet-<instance>

# Versioning Docker
APP_VERSION=2.0.0
APP_INSTANCE=<developpement|recette|production>
GIT_COMMIT=local
BUILD_DATE=unknown

# Standalone (docker-compose-standalone.yml)
APP_HTTP_PORT=8080

# Production avec Traefik (docker-compose.yml)
APP_HOSTNAME=intranet.example.com
